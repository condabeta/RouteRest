# Copy to .env for local overrides (optional — sensible dev defaults exist).
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
# Comma-separated origins allowed to call the API (your deployed frontend).
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
# Optional Postgres URL; defaults to local SQLite if unset.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
NOMINATIM_USER_AGENT=eld-trip-planner/1.0 (you@example.com)
